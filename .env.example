# Production defaults. Override in your local .env if you are using tunnels or SQLite.
WD_NOTABILITY_CORS_ORIGINS=*

# Lookup cache backend
WD_NOTABILITY_LOOKUP_BACKEND=mariadb
WD_NOTABILITY_LOOKUP_DATABASE=wd_notability
WD_NOTABILITY_LOOKUP_HOST=tools.db.svc.wikimedia.cloud
WD_NOTABILITY_LOOKUP_READONLY=0

# Replica hosts for sources that query the wiki databases directly.
# For local tunnels, override these in .env.
WD_NOTABILITY_INLINKS_REPLICA_ENABLED=1
WD_NOTABILITY_INLINKS_REPLICA_HOST=wikidatawiki.analytics.db.svc.wikimedia.cloud
WD_NOTABILITY_INLINKS_REPLICA_PORT=3306
WD_NOTABILITY_INLINKS_REPLICA_DATABASE=wikidatawiki_p
WD_NOTABILITY_CREATIONS_ENABLED=1
WD_NOTABILITY_CREATIONS_HOST=wikidatawiki.analytics.db.svc.wikimedia.cloud
WD_NOTABILITY_CREATIONS_PORT=3306
WD_NOTABILITY_CREATIONS_DATABASE=wikidatawiki_p

# Worker tuning
WD_NOTABILITY_TASK_PROCESSING_TIMEOUT_SECONDS=300
WD_NOTABILITY_TASK_HISTORY_LIMIT=1000

# Wikimedia login for API requests
WD_NOTABILITY_WIKIDATA_LOGIN_ENABLED=0
WD_NOTABILITY_WIKIDATA_USERNAME=
WD_NOTABILITY_WIKIDATA_BOTPASSWORD=
WD_NOTABILITY_WIKIDATA_LOGIN_RETURN_URL=https://www.wikidata.org/
